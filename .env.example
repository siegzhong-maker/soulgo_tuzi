# RAG minimal runnable (9.8) + existing APIs
# Copy to .env.local and fill in values. Do not commit .env.local.

# Google Gemini API Key — used for embeddings (embed-and-store, retrieve)
GOOGLE_GENERATIVE_AI_API_KEY=

# OpenRouter API Key — used for chat, diary, pet/decide, diary-image-comment (existing)
OPENROUTER_API_KEY=

# Optional: vision model for diary image Soul commentary (api/diary-image-comment.js)
# OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-001

# --- Object storage (strongly recommended on Vercel/serverless) ---
# Without a bucket, diary images, collectibles, and furniture fall back to huge data: URLs
# or non-persistent paths; localStorage may strip images (slimSceneForEpisodicStorage).
# Use either AWS S3 or Cloudflare R2 (S3-compatible). IAM/R2 token needs s3:PutObject.

# AWS_S3_BUCKET=
# AWS_REGION=auto
# Optional custom endpoint (leave empty for AWS):
# AWS_S3_ENDPOINT=
# Public base URL where objects are readable (trailing slash optional):
# AWS_S3_PUBLIC_BASE_URL=https://your-bucket.s3.region.amazonaws.com

# Or R2:
# R2_BUCKET=
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=https://pub-xxx.r2.dev
