# RAG minimal runnable (9.8) + existing APIs
# Copy to .env.local and fill in values. Do not commit .env.local.

# Google Gemini API Key — used for embeddings (embed-and-store, retrieve)
GOOGLE_GENERATIVE_AI_API_KEY=

# OpenRouter API Key — used for chat, diary, pet/decide, diary-image-comment (existing)
OPENROUTER_API_KEY=

# Optional: vision model for diary image Soul commentary (api/diary-image-comment.js)
# OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-001
